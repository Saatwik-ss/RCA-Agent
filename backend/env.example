# ─── Copy this file to .env and fill in your values ───────────────────────────
# Never commit .env to git — it contains secrets.

# Groq API — get from https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# LLM model — llama3-70b-8192 is fast and free-tier friendly
# Other options: llama3-8b-8192, mixtral-8x7b-32768, gemma2-9b-it
GROQ_MODEL=llama3-70b-8192

# JWT secret — run `python -c "import secrets; print(secrets.token_hex(32))"` to generate
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars

# SQLite database path (relative to backend/)
DB_PATH=rca_agent.db

# Server port
PORT=5000

# Set to "development" for hot reload and debug mode
FLASK_ENV=production
